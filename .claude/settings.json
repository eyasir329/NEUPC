{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pgrep -f 'next dev' > /dev/null || npm run dev > /tmp/neupc-dev.log 2>&1 &",
            "async": true,
            "statusMessage": "Starting dev server..."
          }
        ]
      }
    ]
  }
}
