# ============================================================================
# NEUPC Website — Environment Variables
# ============================================================================
# Local dev:   Copy this file to `.env.local` and fill in the values.
#              cp .env.example .env.local
#
# Vercel:      Add these in Project Settings → Environment Variables.
#              https://vercel.com/docs/projects/environment-variables
#
# IMPORTANT: Never commit `.env.local` to version control.
# ============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Choose ONE of the following setups:
#
# OPTION 1: Local Supabase (Recommended for development)
# -------------------------------------------------------
# 1. Install Supabase CLI: npm install -g supabase
# 2. Start local server:   npx supabase start
# 3. Copy the output values below (or run: npx supabase status)
#
# OPTION 2: Remote Supabase (For production or cloud development)
# ----------------------------------------------------------------
# Get these from: Supabase Dashboard → Settings → API
#
# ── Local Supabase Configuration ──
# Set to 'true' to explicitly use local Supabase (optional, auto-detected)
SUPABASE_LOCAL=true

# Default local Supabase values (from `npx supabase start` output)
# Replace with your actual keys from the CLI output
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── Remote Supabase Configuration (uncomment for production) ──
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Legacy compatibility keys (optional, not needed for new setups)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-public-key
# SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ── NextAuth.js ──────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000/
NEXTAUTH_SECRET=your-nextauth-secret

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# For Vercel, add your production domain to Authorized redirect URIs:
#   https://your-domain.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Google Drive (File Storage) ──────────────────────────────────────────────
# Required for interacting with Google Drive APIs.
GDRIVE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=your-google-client-secret
GDRIVE_REFRESH_TOKEN=your-google-refresh-token
GDRIVE_FOLDER_ID=your-drive-folder-id

# ── Gemini API (AI Services) ─────────────────────────────────────────────────
# Required for generative AI capabilities.
GEMINI_API_KEY=your-gemini-api-key

# ── LLM Providers (Problem Analysis) ─────────────────────────────────────────
# Configure at least one for AI-powered problem analysis.
# The system will automatically try providers in order until one succeeds.
# All providers below have FREE tiers!
#
# GitHub Models (RECOMMENDED - free with GitHub account, FIRST PRIORITY)
# Uses your GitHub Personal Access Token - https://github.com/settings/tokens
# Create a token with NO special permissions needed (just basic read access)
# Available models: gpt-4o-mini (default), gpt-4o, Meta-Llama-3.1-405B-Instruct, Mistral-large, etc.
# Docs: https://github.com/marketplace/models
GITHUB_TOKEN=your-github-personal-access-token
# Groq (fast & generous free tier) - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Together AI (good free tier) - https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key
# Cerebras (fast inference) - https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your-cerebras-api-key
# OpenRouter (free models available) - https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# OpenAI (paid) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ── Gmail (Nodemailer) ───────────────────────────────────────────────────────
# Required for sending emails via OAuth2
GMAIL_USER=your-email@gmail.com
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# ── Site URL ─────────────────────────────────────────────────────────────────
# Used for SEO metadata, sitemaps, canonical URLs, and OG images.
# On Vercel, set this to your production domain (e.g. https://neupc.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── CLIST API (Competitive Programming Stats) ────────────────────────────────
# Get your API key from: https://clist.by/api/v4/doc/ (requires login)
# Used to fetch rating history, contest stats across multiple platforms
CLIST_API_KEY=your-clist-api-key
CLIST_API_USERNAME=your-clist-username

# ── Browser Extension (Competitive Programming Sync) ─────────────────────────
# Token for authenticating browser extension sync requests
# Generate a secure random token: openssl rand -base64 32
NEUPC_EXTENSION_TOKEN=your-browser-extension-auth-token

# ── Internal API Key (Background Jobs) ───────────────────────────────────────
# Used by background scripts (analyze-problems.js, analyze-submissions.js)
# to authenticate with internal API endpoints without user session
# Generate a secure random token: openssl rand -base64 32
INTERNAL_API_KEY=your-internal-api-key
