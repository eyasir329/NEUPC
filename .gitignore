# Copilot workspace customizations (keep local; don't push)
.github/copilot-instructions.md
.github/hooks/
.github/agents/
/.github/


# production
/build
dist/

# misc
.DS_Store
Thumbs.db
*.pem

# temp / editor swap files
*.swp
*.swo
*~


# Copilot Next.js single-server helpers (keep local; don't push)
scripts/copilot-stop-next-before-dev.mjs
scripts/stop-next-dev.sh
scripts/copilot-cleanup-on-stop.sh
scripts/copilot-session-start.sh
scripts/.next-dev-pids
scripts/agent-next-dev.sh

# Copilot local session state
.copilot/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# test output
.nyc_output/
*.lcov

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Scraper credentials and progress
.env.scraper
scripts/*-progress.json
scripts/codeforces-scrape-progress.json

# Sensitive database files
supabase/remote_data.sql
supabase/seed.sql
supabase/migrations/
*.sql.bak
cloud_*.sql
remote_*.sql

