        "https://web.facebook.com/codingcompetitions/hacker-cup/*",
        "https://www.facebook.com/codingcompetitions/hacker-cup",
        "https://www.facebook.com/codingcompetitions/hacker-cup/*",
        "https://facebook.com/codingcompetitions/hacker-cup",
        "https://facebook.com/codingcompetitions/hacker-cup/*"
      ],
      "js": ["content-scripts/group3/neupc-fbhc.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.cn/submissions/detail/*",
        "https://leetcode.cn/problems/*/submissions/*"
      ],
      "js": ["content-scripts/group4/neupc-leetcode-cn.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.luogu.com.cn/record/*",
        "https://www.luogu.com.cn/problem/*"
      ],
      "js": ["content-scripts/group4/neupc-luogu.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.acwing.com/solution/*",
        "https://www.acwing.com/problem/*"
      ],
      "js": ["content-scripts/group4/neupc-acwing.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://poj.org/status*", "http://poj.org/showsource*"],
      "js": ["content-scripts/group4/neupc-poj.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://acm.hdu.edu.cn/status.php*",
