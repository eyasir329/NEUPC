{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/{path}",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [],
  "crons": [
    {
      "path": "/api/cron/fetch-submissions",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/update-leaderboard",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-tasks",
      "schedule": "0 0 * * *"
    }
  ]
}
